# ===================================================================
# Local-first hackathon stack
# ===================================================================
# 動工前:
#   1. docker compose up -d        ← 啟動 Postgres
#   2. cp .env.local.example .env.local
#   3. (可選) 填 OPENAI_API_KEY，否則只能跑 Demo Mode
# ===================================================================

# ----- Postgres (Docker, 不需改) -----
# Owner: 跑 migration 用
DATABASE_URL=postgresql://owner:owner_pass@localhost:5432/demo_sass_2

# Web user: RLS enforce, 給所有 user-facing 路由
DATABASE_URL_USER=postgresql://web_anon:web_anon_pass@localhost:5432/demo_sass_2

# Admin: BYPASSRLS, 給 platform admin + slug resolver + Inngest worker
DATABASE_URL_ADMIN=postgresql://web_admin:web_admin_pass@localhost:5432/demo_sass_2

# ----- App URL (給 GPT-4o vision call presigned URL 用) -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- AI Provider (V1.5 Track A1: Gemini swap) -----
# 預設 'gemini'; 要 emergency rollback 改 'openai' 即可。
# Gemini 比 GPT-4o 便宜約 8.3x input / 4x output (per Codex web research)。
AI_PROVIDER=gemini

# ----- Google Gemini (V1.5 預設 vision provider) -----
# 沒填 (且 AI_PROVIDER=gemini): 只能跑 Demo Mode, 不能跑 vision smoke test
# 取得: https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# ----- OpenAI (V1 預設 vision provider, V1.5 起改 fallback) -----
# 只在 AI_PROVIDER=openai 時必填
# 取得: https://platform.openai.com → Settings → API Keys
OPENAI_API_KEY=

# ----- Inngest (背景 job, dev 模式自動連 localhost:8288) -----
# Dev 模式不需要設這兩個 (留空即可)
# 真正 deploy 才需要從 https://app.inngest.com 拿
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Demo merchant tenants (hardcoded for V1) -----
DEMO_MERCHANT_AKAMI_ID=11111111-1111-1111-1111-111111111111
DEMO_MERCHANT_AFEN_ID=22222222-2222-2222-2222-222222222222

# ----- Admin gate (V1 single-password, 24hr HMAC session) -----
# 缺任一個 → admin 路由全 503
ADMIN_PASSWORD=changeme
# 用 openssl rand -hex 32 產, 必須 ≥ 32 chars
ADMIN_SESSION_SECRET=please-replace-with-openssl-rand-hex-32-output
