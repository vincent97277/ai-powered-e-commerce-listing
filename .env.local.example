# ===================================================================
# Local-first hackathon stack
# ===================================================================
# 動工前:
#   1. docker compose up -d        ← 啟動 Postgres
#   2. cp .env.local.example .env.local
#   3. (可選) 填 OPENAI_API_KEY，否則只能跑 Demo Mode
# ===================================================================

# ----- Postgres (Docker, 不需改) -----
# Owner: 跑 migration 用
DATABASE_URL=postgresql://owner:owner_pass@localhost:5432/rls_ai_shop

# Web user: RLS enforce, 給所有 user-facing 路由
DATABASE_URL_USER=postgresql://web_anon:web_anon_pass@localhost:5432/rls_ai_shop

# Admin: BYPASSRLS, 給 platform admin + slug resolver + Inngest worker
DATABASE_URL_ADMIN=postgresql://web_admin:web_admin_pass@localhost:5432/rls_ai_shop

# ----- App URL (給 GPT-4o vision call presigned URL 用) -----
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- OpenAI (核心 AI 功能) -----
# 沒填: 只能跑 Demo Mode, 不能跑 vision smoke test
# 取得: https://platform.openai.com → Settings → API Keys
OPENAI_API_KEY=

# ----- Inngest (背景 job, dev 模式自動連 localhost:8288) -----
# Dev 模式不需要設這兩個 (留空即可)
# 真正 deploy 才需要從 https://app.inngest.com 拿
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Demo merchant tenants (hardcoded for V1) -----
DEMO_MERCHANT_AKAMI_ID=11111111-1111-1111-1111-111111111111
DEMO_MERCHANT_AFEN_ID=22222222-2222-2222-2222-222222222222

# ----- Admin gate (V1 single-password, 24hr HMAC session) -----
# 缺任一個 → admin 路由全 503
ADMIN_PASSWORD=changeme
# 用 openssl rand -hex 32 產, 必須 ≥ 32 chars
ADMIN_SESSION_SECRET=please-replace-with-openssl-rand-hex-32-output

# ----- V2 merchant auth (task 103, per-merchant HMAC-bound session) -----
# 缺/<32 chars → /merchant/* 全 503
# 用 openssl rand -hex 32 產, 必須 ≥ 32 chars
MERCHANT_SESSION_SECRET=

# ----- Storage backend (V2.2.4) -----
# local (default): writes to ./public/uploads/, dev only — Vercel/Cloud Run
#                  filesystems are read-only / per-invocation, will lose data
# r2: Cloudflare R2, required for any serverless prod deploy
STORAGE_BACKEND=local

# ----- R2 (only required when STORAGE_BACKEND=r2) -----
# Get these from https://dash.cloudflare.com → R2 → manage tokens
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# Public URL for the bucket. Either *.r2.dev (free) or a custom domain.
R2_PUBLIC_URL=
# V2.2.13: client-side React components need NEXT_PUBLIC_ prefix to see this
# at bundle time. Set this to the SAME value as R2_PUBLIC_URL above.
NEXT_PUBLIC_R2_PUBLIC_URL=
