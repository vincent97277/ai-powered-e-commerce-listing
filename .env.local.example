# ====================================================================
# .env.local 模板 — 複製成 .env.local 後填入實際值
# Hackathon: 全部 R2 設定都從 Cloudflare dashboard 拿
# ====================================================================

# ---------- Cloudflare R2 ----------

# Cloudflare account ID。dash.cloudflare.com 右側欄 "Account ID" 直接複製。
R2_ACCOUNT_ID="abc123abc123abc123abc123abc123ab"

# R2 API token 的 Access Key ID。
# 拿法: dash.cloudflare.com → R2 → Manage R2 API Tokens → Create API Token
#       → 權限選 "Object Read & Write" → 限定 bucket = demo-sass-2-photos
#       → 建完會給你一組 Access Key ID + Secret，只會顯示一次。
R2_ACCESS_KEY_ID="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 同上那組的 Secret Access Key。漏抄就要重建 token。
R2_SECRET_ACCESS_KEY="yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy"

# Bucket 名稱。dashboard 上自己看到的那個名字 (大小寫敏感)。
R2_BUCKET="demo-sass-2-photos"

# 公開讀取網址 (給瀏覽器顯示圖用)。
# 拿法: bucket → Settings → Public access → Allow Access
#       → 開完會給一組 https://pub-xxxxxxxx.r2.dev
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# S3 API endpoint (R2 client 用的)。
# 格式固定: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# 注意: 必須帶 https://，不要漏；不要在尾巴多斜線。
R2_ENDPOINT="https://abc123abc123abc123abc123abc123ab.r2.cloudflarestorage.com"

# ---------- Inngest (其他 agent 會補) ----------
# INNGEST_EVENT_KEY=""
# INNGEST_SIGNING_KEY=""

# ---------- Neon / OpenAI (其他 agent 會補) ----------
# DATABASE_URL=""
# OPENAI_API_KEY=""
